import streamlit as st
from openai import OpenAI
from duckduckgo_search import DDGS

st.set_page_config(page_title="IZ AI v2.0", page_icon="🤖")
st.title("IZ AI v2.0 🤖")
st.caption("Chatbot AI + Bisa Cari Internet")

# 1. Input API Key
api_key = st.text_input("Masukkan API Key OpenAI:", type="password")
if not api_key:
    st.warning("Tempel API Key `sk-...` kamu dulu ya")
    st.stop()

client = OpenAI(api_key=api_key)

# 2. Chat History
if "chat" not in st.session_state:
    st.session_state.chat = []

for msg in st.session_state.chat:
    with st.chat_message(msg["role"]):
        st.write(msg["content"])

# 3. Input User
user_input = st.chat_input("Tanya apa aja ke IZ AI...")

if user_input:
    st.session_state.chat.append({"role": "user", "content": user_input})
    with st.chat_message("user"):
        st.write(user_input)

    with st.chat_message("assistant"):
        with st.spinner("IZ AI lagi mikir..."):
            try:
                # Cari di internet dulu
                search_results = DDGS().text(user_input, max_results=3)
                context = "\n".join([r['body'] for r in search_results])
                
                # Kirim ke GPT bareng hasil search
                response = client.chat.completions.create(
                    model="gpt-4o-mini", # Murah & cepet
                    messages=[
                        {"role": "system", "content": f"Kamu IZ AI. Jawab pakai Bahasa Indonesia. Ini data dari internet: {context}"},
                        {"role": "user", "content": user_input}
                    ]
                )
                reply = response.choices[0].message.content
            except Exception as e:
                reply = f"Aduh error: {e}"

            st.write(reply)
            st.session_state.chat.append({"role": "assistant", "content": reply})
